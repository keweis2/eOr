<?xml version="1.0" encoding="utf-8"?>
<!--
  Donkey-head silhouette derived from ic_launcher_foreground (ears + head + snout),
  flattened to a single fill so it can be tinted next to the "eOr" wordmark.
  Coordinates are the launcher art's head region shifted by (-30,-18) into a 48x48 box.
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="48dp"
    android:height="48dp"
    android:viewportWidth="48"
    android:viewportHeight="48">

    <!-- Left ear (rounded tip) -->
    <path android:fillColor="#000000"
          android:pathData="M10,20 L6.5,4 Q10,0.5 13.5,4 L18,22 Z"/>
    <!-- Right ear (rounded tip) -->
    <path android:fillColor="#000000"
          android:pathData="M38,20 L34.5,4 Q38,0.5 41.5,4 L30,22 Z"/>
    <!-- Head -->
    <path android:fillColor="#000000"
          android:pathData="M6,32 A18,16 0 1 0 42,32 A18,16 0 1 0 6,32 Z"/>
    <!-- Snout -->
    <path android:fillColor="#000000"
          android:pathData="M14,41 A10,5 0 1 0 34,41 A10,5 0 1 0 14,41 Z"/>
</vector>
